# WaveForge Phase 2 — 環境變數設定
# 複製此檔案為 .env.local 並填入實際值（.env.local 已在 .gitignore）
# 請勿將 .env.local 提交至 Git！

# ── Supabase（Auth + DB + Edge Functions）──────────────────
# 從 Supabase Dashboard → Project Settings → API 取得
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── HuggingFace Spaces（Demucs 分軌後端）──────────────────
# 格式：https://<你的HF帳號>-demucs-waveforge.hf.space
# 部署步驟詳見 hf-space/README.md
VITE_HF_ENDPOINT=https://your-username-demucs-waveforge.hf.space
